# --- SETĂRI GLOBALE ---
SKIP_FRAMES = 2
CONF_THRESH = 0.30
CONFIG_FILE = "cameras.json"

# Filtru anti-zgomot pentru direcție (pixeli pe normală). Crește dacă ai numărări false.
MIN_CROSS_NORM_DELTA = 6

# Setam timeout extrem de scurt pt OpenCV (2 secunde) ca sa verifice caile instantaneu
os.environ["OPENCV_FFMPEG_CAPTURE_OPTIONS"] = "timeout;2000"

