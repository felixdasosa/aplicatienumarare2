# --- STRUCTURI DE DATE DINAMICE ---
cameras_config = {}
camera_data = {}
history_data = {}
thread_flags = {}
latest_frames = {}
system_logs = []

TIME_SLOTS = [f"{h:02d}:00-{h+2:02d}:00" for h in range(0, 24, 2)]

def get_current_slot():
    now = datetime.now()
    start_h = (now.hour // 2) * 2
    return f"{start_h:02d}:00-{start_h+2:02d}:00"

def add_log(cam_name, event_type):
    now_str = datetime.now().strftime("%H:%M:%S | %d-%m-%Y")
    log_entry = {"time": now_str, "cam": cam_name, "event": event_type}
    system_logs.insert(0, log_entry)
    if len(system_logs) > 1000:
        system_logs.pop()

def load_config():
    global cameras_config
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE, 'r') as f:
                cameras_config = json.load(f)
        except:
            cameras_config = {}
    else:
        cameras_config = {}

def save_config():
    with open(CONFIG_FILE, 'w') as f:
        json.dump(cameras_config, f, indent=4)

def init_camera_structures(cam_id):
    if cam_id not in camera_data:
        camera_data[cam_id] = {"in": 0, "out": 0, "status": "Se conecteaza...", "name": cameras_config[cam_id].get("name", cam_id)}
    if cam_id not in history_data:
        history_data[cam_id] = {slot: {"in": 0, "out": 0} for slot in TIME_SLOTS}

def ccw(A, B, C):
    return (C[1]-A[1]) * (B[0]-A[0]) > (B[1]-A[1]) * (C[0]-A[0])

def intersect(A, B, C, D):
    return ccw(A, C, D) != ccw(B, C, D) and ccw(A, B, C) != ccw(A, B, D)

# --- PROCESARE VIDEO DIRECTA & INTELIGENTA ---
def process_camera(cam_id):
    model = YOLO('yolov8n.pt')
    print(f"[THREAD] Start Camera {cam_id}")
    cap = None

    while thread_flags.get(cam_id, False):
        config = cameras_config.get(cam_id)
        if not config:
            break

        user = config['user']
        password = config['password']
        ip = config['ip']
        port_http = config.get('port_http', '80')
        port_rtsp = config.get('port_rtsp', '554')
        canal = config.get('channel', '1').strip()
        if not canal:
            canal = "1"

        # 1. HANDSHAKE HTTP INSTANTANEU (Doar ca sa deblocam fluxul NVR-ului)
        camera_data[cam_id]["status"] = "Se conecteaza..."
        http_url = f"http://{ip}:{port_http}"
        try:
            requests.get(f"{http_url}/ISAPI/System/deviceInfo", auth=HTTPDigestAuth(user, password), timeout=2)
        except Exception:
            pass  # Ignoram si mergem direct la video

        # 2. DETERMINARE AUTOMATA A CAII VIDEO (Silentios si rapid)
        safe_user = urllib.parse.quote(user)
        safe_pass = urllib.parse.quote(password)
        base_url_rtsp = f"rtsp://{safe_user}:{safe_pass}@{ip}:{port_rtsp}"

        working_url = config.get('working_url')

        if not working_url:
            # Ordinea in care incercam: DVR/NVR Normal -> NVR PoE Proxy -> Dahua
            paths_to_try = [
                f"/Streaming/Channels/{canal}01",
                f"/ISAPI/Streaming/channels/{canal}01",
                f"/cam/realmonitor?channel={canal}&subtype=0"
            ]

            for path in paths_to_try:
                if not thread_flags.get(cam_id, False):
                    break
                test_url = base_url_rtsp + path
                test_cap = cv2.VideoCapture(test_url)
                if test_cap.isOpened():
                    ret, _ = test_cap.read()
                    if ret:
                        working_url = test_url
                        cameras_config[cam_id]['working_url'] = working_url
                        save_config()
                        test_cap.release()
                        break
                test_cap.release()

            if not working_url:
                camera_data[cam_id]["status"] = "EROARE CONEXIUNE"
                time.sleep(5)
                continue

        # 3. RULARE FLUX VIDEO
        scale_x = 640 / 1280.0
        scale_y = 360 / 720.0

        track_history = {}
        counted_ids = set()   # IMPORTANT: set, nu list
        frame_count = 0

        cap = cv2.VideoCapture(working_url)

        while thread_flags.get(cam_id, False):
            if cam_id not in cameras_config:
                break

            ret, frame = cap.read()
            if not ret:
                camera_data[cam_id]["status"] = "OFFLINE"
                cap.release()
                time.sleep(3)
                if thread_flags.get(cam_id, False):
                    # Ping HTTP in caz ca s-a intrerupt sesiunea
                    try:
                        requests.get(f"{http_url}/ISAPI/System/deviceInfo", auth=HTTPDigestAuth(user, password), timeout=2)
                    except:
                        pass
                    cap = cv2.VideoCapture(working_url)
                continue

            camera_data[cam_id]["status"] = "ONLINE"
            camera_data[cam_id]["name"] = cameras_config[cam_id]["name"]

            current_config = cameras_config[cam_id]

            has_line = False
            pt1_cfg = current_config.get('pt1', None)
            pt2_cfg = current_config.get('pt2', None)
            if pt1_cfg is not None and pt2_cfg is not None:
                if pt1_cfg != [0, 0] and pt2_cfg != [0, 0]:
                    has_line = True

            frame_small = cv2.resize(frame, (640, 360))
            frame_disp = frame_small.copy()

            if has_line:
                line_start = tuple(pt1_cfg)
                line_end = tuple(pt2_cfg)
                flip_dir = current_config.get('flip_dir', 1)

                L1 = (int(line_start[0] * scale_x), int(line_start[1] * scale_y))
                L2 = (int(line_end[0] * scale_x), int(line_end[1] * scale_y))

                if L1 != L2:
                    cv2.line(frame_disp, L1, L2, (0, 255, 0), 2)
                    dx = L2[0] - L1[0]
                    dy = L2[1] - L1[1]
                    length = math.sqrt(dx**2 + dy**2)
                    if length > 0:
                        nx = -dy / length
                        ny = dx / length
                        cx = (L1[0] + L2[0]) // 2
                        cy = (L1[1] + L2[1]) // 2
                        tip_x = int(cx + nx * 40 * flip_dir)
                        tip_y = int(cy + ny * 40 * flip_dir)
                        cv2.arrowedLine(frame_disp, (cx, cy), (tip_x, tip_y), (0, 255, 255), 3, tipLength=0.3)
                        cv2.putText(frame_disp, "IN", (tip_x, tip_y - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

            ret_jpg, buffer = cv2.imencode('.jpg', frame_disp)
            if ret_jpg:
                latest_frames[cam_id] = buffer.tobytes()

            frame_count += 1
            if frame_count % SKIP_FRAMES != 0:
                continue

            results = model.track(
                frame_small,
                persist=True,
                verbose=False,
                imgsz=320,
                conf=CONF_THRESH,
                classes=[0],
                tracker="bytetrack.yaml"
            )

            current_ids_in_frame = []

            if results and results[0].boxes and results[0].boxes.id is not None:
                boxes = results[0].boxes.xyxy.cpu().numpy()
                ids = results[0].boxes.id.int().cpu().tolist()

                for box, track_id in zip(boxes, ids):
                    current_ids_in_frame.append(track_id)
                    x1, y1, x2, y2 = map(int, box)
                    curr_point = ((x1 + x2) // 2, y2)  # punct "picior" bbox

                    if has_line and track_id in track_history and track_id not in counted_ids:
                        prev_point = track_history[track_id]

                        # Detectează intersecția segmentului de mișcare cu linia
                        if intersect(prev_point, curr_point, L1, L2):
                            current_slot = get_current_slot()
                            flip_dir = current_config.get('flip_dir', 1)

                            # Vector linie
                            vx = L2[0] - L1[0]
                            vy = L2[1] - L1[1]

                            # Normală la linie, orientată pe direcția săgeții "IN"
                            nx = -vy * flip_dir
                            ny =  vx * flip_dir

                            nlen = math.sqrt(nx * nx + ny * ny) + 1e-9
                            nx /= nlen
                            ny /= nlen

                            # Semn față de linie (partea în care se află punctul)
                            s_prev = (prev_point[0] - L1[0]) * nx + (prev_point[1] - L1[1]) * ny
                            s_curr = (curr_point[0] - L1[0]) * nx + (curr_point[1] - L1[1]) * ny

                            # Mișcare proiectată pe normală: dn > 0 => sensul săgeții (IN)
                            dn = (curr_point[0] - prev_point[0]) * nx + (curr_point[1] - prev_point[1]) * ny

                            crossed = (s_prev < 0 and s_curr > 0) or (s_prev > 0 and s_curr < 0)

                            # Filtru anti-zgomot: mișcare minimă pe normală
                            if crossed and abs(dn) >= MIN_CROSS_NORM_DELTA:
                                if dn > 0:
                                    camera_data[cam_id]["in"] += 1
                                    history_data[cam_id][current_slot]["in"] += 1
                                    counted_ids.add(track_id)
                                    add_log(cameras_config[cam_id]["name"], "INTRARE")
                                else:
                                    camera_data[cam_id]["out"] += 1
                                    history_data[cam_id][current_slot]["out"] += 1
                                    counted_ids.add(track_id)
                                    add_log(cameras_config[cam_id]["name"], "IESIRE")

                    track_history[track_id] = curr_point

            if frame_count % 100 == 0:
                track_history = {k: v for k, v in track_history.items() if k in current_ids_in_frame}

            time.sleep(0.01)

        if cap:
            cap.release()
    print(f"[THREAD] Stop Camera {cam_id}")

def start_camera_thread(cam_id):
    if cam_id not in thread_flags or not thread_flags[cam_id]:
        thread_flags[cam_id] = True
        t = threading.Thread(target=process_camera, args=(cam_id,))
        t.daemon = True
        t.start()

def stop_camera_thread(cam_id):
    if cam_id in thread_flags:
        thread_flags[cam_id] = False

