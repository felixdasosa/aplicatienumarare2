                    <div style="margin-top: 5px; display: flex; gap: 5px;">
                        <button type="button" class="btn-quick-pass" onclick="fillPassword('Ifis_2022')">🔑 Ifis</button>
                        <button type="button" class="btn-quick-pass" onclick="fillPassword('Asfa_2024')">🔑 Asfalia</button>
                    </div>
                </div>
            </div>

            <div style="margin-top:20px; border-top:1px solid #444; padding-top:15px;">
                <label style="color:#ffb300; font-weight:bold;">Alege Camera din NVR / DVR</label>
                <div style="display:flex; gap:10px; align-items:center;">
                    <select id="f_channel_select" style="flex:1; padding: 12px; font-size: 1.1em;">
                        <script>
                            for(let i=1; i<=32; i++) {
                                document.write('<option value="'+i+'">Canal ' + i + '</option>');
                            }
                        </script>
                    </select>
                    <button type="button" class="btn-search" id="btn_search_ch" onclick="fetchChannels()">🔄 Descarcă Numele Camerelor</button>
                </div>
            </div>

            <button class="btn-submit" onclick="saveCamera()">Salvează Camera</button>
        </div>

        <table>
            <thead><tr><th>ID</th><th>Nume</th><th>Conexiune (IP:Porturi)</th><th>Status</th><th>Acțiuni</th></tr></thead>
            <tbody id="config-table-body"></tbody>
        </table>
    </div>

    <div id="view-modal" class="modal-overlay">
        <div class="modal-content">
            <h2 id="view-modal-title" style="margin-top:0; color:#4facfe;">Vizualizare Live</h2>
