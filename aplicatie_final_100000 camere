                <img id="view-stream-img" />
            </div>
            <div class="modal-buttons" style="display:block; text-align:center;"><button class="btn-cancel" onclick="closeViewModal()">❌ Închide Fereastra</button></div>
        </div>
    </div>

    <div id="draw-modal" class="modal-overlay">
        <div class="modal-content">
            <h2 style="margin-top:0; color:#ffb300; margin-bottom:5px;">Editează Linia de Detecție</h2>
            <p style="color:#aaa; font-size:0.9em; margin-top:0;">Trage cu mouse-ul peste imagine pentru a plasa linia de detecție.<br>Săgeata galbenă indică direcția de <b>INTRARE</b>.</p>
            <div class="video-container">
                <img id="stream-img" />
                <canvas id="draw-canvas" width="640" height="360"></canvas>
            </div>
            <div class="modal-buttons">
                <button class="btn-save-line" onclick="saveDrawnLine()">✅ Salvează Configurația</button>
                <button class="btn-flip" onclick="flipArrow()">🔄 Inversează Direcția</button>
                <button class="btn-clear" onclick="clearLine()">🧹 Șterge Linia</button>
                <button class="btn-cancel" onclick="closeDrawModal()">❌ Închide Fereastra</button>
            </div>
        </div>
    </div>

    <script>
        let currentCameras = {};
        let currentLiveDataCache = {};
        let activeDrawCamId = null;

        let canvas = document.getElementById('draw-canvas');
        let ctx = canvas.getContext('2d');
        let isDrawing = false;
        let startX = 0, startY = 0, endX = 0, endY = 0;
        let flipDirection = 1;

        const emptyImageSrc = "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=";

        function fillPassword(pwd) {
            document.getElementById('f_pass').value = pwd;
        }

        function fetchChannels() {
            let ip = document.getElementById('f_ip').value;
            let port = document.getElementById('f_port_http').value;
            let user = document.getElementById('f_user').value;
            let pass = document.getElementById('f_pass').value;

            if(!ip || !port || !user || !pass) {
                alert("Te rugam sa completezi IP, Port HTTP, User si Parola inainte de a descarca camerele!");
                return;
            }

            let btn = document.getElementById('btn_search_ch');
            let oldText = btn.innerText;
            btn.innerText = "⏳ Se preiau datele...";
            btn.disabled = true;

            fetch('/fetch_channels', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ip: ip, port_http: port, user: user, password: pass})
            }).then(r => r.json()).then(res => {
                btn.innerText = oldText;
                btn.disabled = false;

                if(res.success && res.channels.length > 0) {
                    let sel = document.getElementById('f_channel_select');
                    sel.innerHTML = '';
                    res.channels.forEach(ch => {
                        let opt = document.createElement('option');
                        opt.value = ch.id;
                        opt.innerText = `[Canal ${ch.id}] - ${ch.name}`;
                        sel.appendChild(opt);
                    });
                    alert("Camerele au fost gasite si adaugate in lista!");
                } else {
                    alert("Nu am putut incarca numele din NVR. Poti alege canalul dorit direct din lista de 1-32.");
                }
            }).catch(e => {
                btn.innerText = oldText;
                btn.disabled = false;
                alert("Eroare de conectare HTTP.");
            });
        }

        function drawLineAndArrow(x1, y1, x2, y2) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (x1 === x2 && y1 === y2) return;

            ctx.beginPath();
            ctx.moveTo(x1, y1);
            ctx.lineTo(x2, y2);
            ctx.strokeStyle = '#00e676';
            ctx.lineWidth = 3;
            ctx.stroke();

            let cx = (x1 + x2) / 2;
            let cy = (y1 + y2) / 2;
            let dx = x2 - x1;
            let dy = y2 - y1;
            let len = Math.sqrt(dx*dx + dy*dy);
            if(len === 0) return;

            let nx = (-dy / len) * flipDirection;
            let ny = (dx / len) * flipDirection;
            let arrowLength = 50;
            let tipX = cx + nx * arrowLength;
            let tipY = cy + ny * arrowLength;

            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.lineTo(tipX, tipY);
            ctx.strokeStyle = '#ffb300';
            ctx.lineWidth = 3;
            ctx.stroke();

            let angle = Math.atan2(tipY - cy, tipX - cx);
            ctx.beginPath();
            ctx.moveTo(tipX, tipY);
            ctx.lineTo(tipX - 15 * Math.cos(angle - Math.PI/6), tipY - 15 * Math.sin(angle - Math.PI/6));
            ctx.lineTo(tipX - 15 * Math.cos(angle + Math.PI/6), tipY - 15 * Math.sin(angle + Math.PI/6));
            ctx.closePath();
            ctx.fillStyle = '#ffb300';
            ctx.fill();

            ctx.fillStyle = '#00e676';
            ctx.font = "bold 16px Arial";
            ctx.fillText("INTRARE", tipX + 10, tipY + 10);
        }

        function flipArrow() {
            flipDirection *= -1;
            if(startX !== endX || startY !== endY) {
                drawLineAndArrow(startX, startY, endX, endY);
            }
        }

        function clearLine() {
            startX = 0; startY = 0; endX = 0; endY = 0;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        }

        canvas.addEventListener('mousedown', (e) => {
            const rect = canvas.getBoundingClientRect();
            startX = e.clientX - rect.left; startY = e.clientY - rect.top;
            isDrawing = true;
        });

        canvas.addEventListener('mousemove', (e) => {
            if (!isDrawing) return;
            const rect = canvas.getBoundingClientRect();
            let currentX = e.clientX - rect.left; let currentY = e.clientY - rect.top;
            drawLineAndArrow(startX, startY, currentX, currentY);
        });

        canvas.addEventListener('mouseup', (e) => {
            if (!isDrawing) return;
            const rect = canvas.getBoundingClientRect();
            endX = e.clientX - rect.left; endY = e.clientY - rect.top;
            isDrawing = false;
            drawLineAndArrow(startX, startY, endX, endY);
        });

        canvas.addEventListener('mouseleave', (e) => {
            if (isDrawing) {
                isDrawing = false;
                drawLineAndArrow(startX, startY, endX, endY);
            }
        });

        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(tabName).classList.add('active');
            document.getElementById('btn-' + tabName).classList.add('active');
        }

        function updateData() {
            fetch('/data').then(r => r.json()).then(data => {
                const live = data.live;
                const history = data.history;
                const logs = data.logs;
                currentLiveDataCache = live;
                const camIds = Object.keys(live);

                const grid = document.getElementById('live-grid');
                camIds.forEach(id => {
                    const info = live[id];
                    let card = document.getElementById(`card-${id}`);
                    if (!card) {
                        card = document.createElement('div');
                        card.id = `card-${id}`;
                        grid.appendChild(card);
                    }
                    const statusClass = info.status === "ONLINE" ? "online" : "offline";
                    let statusDot = info.status === "ONLINE" ? "🟢 ONLINE" : "🔴 OFFLINE";
                    if(info.status.includes("conecteaza")) statusDot = "🟡 CONECTARE...";

                    card.className = `card ${statusClass}`;
                    card.innerHTML = `
                        <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                            <span style="font-weight:bold;">${info.name}</span>
                            <span style="font-size:0.8em; color:#aaa;">${statusDot}</span>
                        </div>
                        <div class="stats">
                            <div><div class="val in">${info.in}</div><div class="lbl">INTRĂRI</div></div>
                            <div><div class="val out">${info.out}</div><div class="lbl">IEȘIRI</div></div>
                        </div>
                        <div class="total-box"><div class="val-total">${info.in - info.out}</div><div style="font-size:0.8em;">TOTAL PERSOANE</div></div>
                        <button class="btn-play" onclick="openViewModal('${id}')">▶ Vezi Live</button>
                    `;
                });
                Array.from(grid.children).forEach(child => {
                    const cid = child.id.replace('card-', '');
                    if(!camIds.includes(cid)) grid.removeChild(child);
                });

                if(camIds.length > 0) {
                    const thead = document.getElementById('history-head');
                    const tbody = document.getElementById('history-body');
                    let headHtml1 = `<tr><th rowspan="2">Interval Orar</th>`;
                    let headHtml2 = `<tr>`;
                    camIds.forEach(id => {
                        headHtml1 += `<th colspan="3">${live[id].name}</th><th style="width:5px;"></th>`;
                        headHtml2 += `<th style="font-size:0.8em;">IN</th><th style="font-size:0.8em;">OUT</th><th style="font-size:0.8em;">TOT</th><th></th>`;
                    });
                    headHtml1 += `</tr>`; headHtml2 += `</tr>`;
                    thead.innerHTML = headHtml1 + headHtml2;

                    tbody.innerHTML = '';
                    const timeSlots = Object.keys(history[camIds[0]] || {});
                    timeSlots.forEach(slot => {
                        let row = `<tr><td>${slot}</td>`;
                        camIds.forEach(id => {
                            let hData = history[id][slot] || {in:0, out:0};
                            row += `<td><span class="h-in">${hData.in}</span></td><td><span class="h-out">${hData.out}</span></td><td><span style="font-weight:bold;">${hData.in - hData.out}</span></td><td style="border-right: 2px solid #555;"></td>`;
                        });
                        row += `</tr>`;
                        tbody.innerHTML += row;
                    });
                }

                const logsBody = document.getElementById('logs-body');
                logsBody.innerHTML = '';
                if(logs) {
                    logs.forEach(log => {
                        const eventClass = log.event === "INTRARE" ? "log-in" : "log-out";
                        logsBody.innerHTML += `<tr><td>${log.time}</td><td>${log.cam}</td><td class="${eventClass}">${log.event}</td></tr>`;
                    });
                }

                if(document.getElementById('config').classList.contains('active')) {
                    camIds.forEach(id => {
                        let rowStatus = document.getElementById(`status_td_${id}`);
                        if(rowStatus) {
                            let s = live[id].status;
                            let html = "";
                            if(s.includes("conecteaza")) html = "<span style='color:#ffb300'>🌐 Conectare rapida...</span>";
                            else if(s === "ONLINE") html = "<span style='color:#00e676'>🟢 ONLINE</span>";
                            else html = `<span style='color:#ff1744'>🔴 ${s}</span>`;
                            rowStatus.innerHTML = html;
                        }
                    });
                }
            });
        }

        function loadSettings() {
            fetch('/get_cameras').then(r => r.json()).then(data => {
                currentCameras = data;
                const tbody = document.getElementById('config-table-body');
                tbody.innerHTML = '';
                Object.entries(data).forEach(([id, cam]) => {
                    let s_ui = currentLiveDataCache[id] ? currentLiveDataCache[id].status : "Asteptare...";
                    let statusHtml = "<span style='color:#aaa'>...</span>";

                    if(s_ui.includes("conecteaza")) statusHtml = "<span style='color:#ffb300'>🌐 Conectare rapida...</span>";
                    else if(s_ui === "ONLINE") statusHtml = "<span style='color:#00e676'>🟢 ONLINE</span>";
                    else statusHtml = `<span style='color:#ff1744'>🔴 ${s_ui}</span>`;

                    tbody.innerHTML += `
                        <tr>
                            <td>${id}</td>
                            <td>${cam.name} (Ch: ${cam.channel})</td>
                            <td style="font-size:0.9em; color:#ddd;">H: ${cam.port_http} / R: ${cam.port_rtsp}</td>
                            <td id="status_td_${id}">${statusHtml}</td>
                            <td>
                                <button class="btn-edit" onclick="editCamera('${id}')">Setări</button>
                                <button class="btn-draw" onclick="openDrawModal('${id}')">Deseneaza Linie</button>
                                <button class="btn-delete" onclick="deleteCamera('${id}')">Șterge</button>
                            </td>
                        </tr>
                    `;
                });
            });
        }

        function resetForm() {
            document.getElementById('f_id').value = '';
            document.getElementById('f_id').readOnly = false;
            document.getElementById('f_name').value = '';
            document.getElementById('f_ip').value = '';
            document.getElementById('f_port_http').value = '';
            document.getElementById('f_port_rtsp').value = '';
            document.getElementById('f_user').value = 'admin';
            document.getElementById('f_pass').value = 'Ifis_2022';

            let sel = document.getElementById('f_channel_select');
            sel.innerHTML = '';
            for(let i=1; i<=32; i++) {
                let opt = document.createElement('option');
                opt.value = i;
                opt.innerText = 'Canal ' + i;
                sel.appendChild(opt);
            }
        }

        function saveCamera() {
            const data = {
                id: document.getElementById('f_id').value,
                name: document.getElementById('f_name').value,
                ip: document.getElementById('f_ip').value,
                port_http: document.getElementById('f_port_http').value,
                port_rtsp: document.getElementById('f_port_rtsp').value,
                user: document.getElementById('f_user').value,
                password: document.getElementById('f_pass').value,
                channel: document.getElementById('f_channel_select').value
            };
            if(!data.id || !data.ip || !data.port_http || !data.port_rtsp) return alert('Completeaza ID, IP si ambele Porturi!');

            fetch('/save_camera', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })
            .then(r => r.json()).then(res => {
                if(res.success) {
                    resetForm();
                    loadSettings();
                }
            });
        }

        function editCamera(id) {
            const cam = currentCameras[id];
            document.getElementById('f_id').value = id; document.getElementById('f_id').readOnly = true;
            document.getElementById('f_name').value = cam.name; document.getElementById('f_ip').value = cam.ip;
            document.getElementById('f_port_http').value = cam.port_http;
            document.getElementById('f_port_rtsp').value = cam.port_rtsp;
            document.getElementById('f_user').value = cam.user;
            document.getElementById('f_pass').value = cam.password;

            let sel = document.getElementById('f_channel_select');
            let exists = Array.from(sel.options).some(opt => opt.value === cam.channel);
            if(!exists && cam.channel) {
                let opt = document.createElement('option');
                opt.value = cam.channel;
                opt.innerText = `[Canal] - ${cam.channel}`;
                sel.appendChild(opt);
            }
            sel.value = cam.channel || "1";
            window.scrollTo(0, 0);
        }

        function deleteCamera(id) {
            if(confirm('Sigur vrei să ștergi camera complet?')) {
                fetch('/delete_camera', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({id: id}) })
                .then(r => r.json()).then(res => {
                    if(res.success) {
                        resetForm();
                        loadSettings();
                    }
                });
            }
        }

        function openViewModal(camId) {
            document.getElementById('view-modal').style.display = 'block';
            document.getElementById('view-stream-img').src = "/video_feed/" + camId + "?t=" + new Date().getTime();
            let camName = currentLiveDataCache[camId] ? currentLiveDataCache[camId].name : camId;
            document.getElementById('view-modal-title').innerText = "Live: " + camName;
        }

        function closeViewModal() {
            document.getElementById('view-modal').style.display = 'none';
            document.getElementById('view-stream-img').src = emptyImageSrc;
        }

        function openDrawModal(camId) {
            activeDrawCamId = camId;
            document.getElementById('draw-modal').style.display = 'block';
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            let camData = currentCameras[camId];
            if(camData && camData.pt1 && camData.pt2 && camData.pt1[0] !== 0) {
                startX = camData.pt1[0] / 2; startY = camData.pt1[1] / 2;
                endX = camData.pt2[0] / 2; endY = camData.pt2[1] / 2;
                flipDirection = camData.flip_dir || 1;
                drawLineAndArrow(startX, startY, endX, endY);
            } else {
                startX = 0; startY = 0; endX = 0; endY = 0;
                flipDirection = 1;
            }

            document.getElementById('stream-img').src = "/video_feed/" + camId + "?t=" + new Date().getTime();
        }

        function closeDrawModal() {
            document.getElementById('draw-modal').style.display = 'none';
            document.getElementById('stream-img').src = emptyImageSrc;
            activeDrawCamId = null;
        }

        function saveDrawnLine() {
            if(!activeDrawCamId) return;

            let pt1 = [0,0]; let pt2 = [0,0];
            if(startX !== endX || startY !== endY) {
                const scale = 2;
                pt1 = [Math.round(startX * scale), Math.round(startY * scale)];
                pt2 = [Math.round(endX * scale), Math.round(endY * scale)];
            }

            fetch('/save_line', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: activeDrawCamId, pt1: pt1, pt2: pt2, flip_dir: flipDirection })
            }).then(r => r.json()).then(res => {
                if(res.success) {
                    alert('Configurația a fost salvată cu succes!');
                    closeDrawModal();
                }
            });
        }

        setInterval(updateData, 1000);
        updateData();
    </script>
</body>
</html>
