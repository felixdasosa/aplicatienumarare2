@app.route('/save_camera', methods=['POST'])
def save_camera():
    data = request.json
    cam_id = data.get('id')
    is_edit = cam_id in cameras_config

    if is_edit:
        stop_camera_thread(cam_id)
        time.sleep(1)

    old_pt1 = cameras_config.get(cam_id, {}).get("pt1", None)
    old_pt2 = cameras_config.get(cam_id, {}).get("pt2", None)
    old_flip = cameras_config.get(cam_id, {}).get("flip_dir", 1)

    cameras_config[cam_id] = {
        "name": data.get('name'),
        "ip": data.get('ip'),
        "port_http": data.get('port_http'),
        "port_rtsp": data.get('port_rtsp'),
        "user": data.get('user'),
        "password": data.get('password'),
        "channel": data.get('channel', '1'),
        "pt1": old_pt1,
        "pt2": old_pt2,
        "flip_dir": old_flip,
        "working_url": None
    }

    save_config()
    init_camera_structures(cam_id)
    start_camera_thread(cam_id)
    return jsonify({"success": True, "id": cam_id})

@app.route('/save_line', methods=['POST'])
def save_line():
    data = request.json
    cam_id = data.get('id')
    if cam_id in cameras_config:
        cameras_config[cam_id]['pt1'] = data.get('pt1')
        cameras_config[cam_id]['pt2'] = data.get('pt2')
        cameras_config[cam_id]['flip_dir'] = data.get('flip_dir', 1)
        save_config()
        return jsonify({"success": True})
    return jsonify({"success": False})

@app.route('/delete_camera', methods=['POST'])
def delete_camera():
    cam_id = request.json.get('id')
    if cam_id in cameras_config:
        stop_camera_thread(cam_id)
        del cameras_config[cam_id]
        camera_data.pop(cam_id, None)
        history_data.pop(cam_id, None)
        latest_frames.pop(cam_id, None)
        save_config()
        return jsonify({"success": True})
    return jsonify({"success": False})

@app.route('/fetch_channels', methods=['POST'])
def fetch_channels():
    data = request.json
    ip = data.get('ip')
    port = data.get('port_http', '80')
    user = data.get('user')
    password = data.get('password')

    url_hikvision = f"http://{ip}:{port}/ISAPI/Streaming/channels"
    url_dahua = f"http://{ip}:{port}/cgi-bin/configManager.cgi?action=getConfig&name=ChannelTitle"

    channels_found = []

    try:
        resp = requests.get(url_hikvision, auth=HTTPDigestAuth(user, password), timeout=3)
        if resp.status_code == 401:
            resp = requests.get(url_hikvision, auth=HTTPBasicAuth(user, password), timeout=3)

        if resp.status_code == 200:
            ids = re.findall(r'<id[^>]*>(.*?)</id>', resp.text)
            names = re.findall(r'<channelName[^>]*>(.*?)</channelName>', resp.text)
            for i in range(len(ids)):
                cid = str(ids[i])
                if cid.endswith('01'):
                    real_ch = cid[:-2]
                    cname = names[i] if i < len(names) else f"Camera {real_ch}"
                    channels_found.append({"id": real_ch, "name": cname})
            if channels_found:
                return jsonify({"success": True, "channels": channels_found})
    except:
        pass

    try:
        resp = requests.get(url_dahua, auth=HTTPDigestAuth(user, password), timeout=3)
        if resp.status_code == 200:
            lines = resp.text.split('\n')
            for line in lines:
                if 'table.ChannelTitle[' in line and '].Name=' in line:
                    parts = line.split('=', 1)
                    if len(parts) == 2:
                        name = parts[1].strip()
                        idx = re.search(r'\[(.*?)\]', line).group(1)
                        real_ch = str(int(idx) + 1)
                        channels_found.append({"id": real_ch, "name": name})
            if channels_found:
                return jsonify({"success": True, "channels": channels_found})
    except:
        pass

    return jsonify({"success": False, "error": "Nu am putut prelua canalele. Introdu canalul manual."})

@app.route('/export_logs')
def export_logs():
    si = StringIO()
    cw = csv.writer(si)
    cw.writerow(['Data si Ora', 'Camera', 'Eveniment'])
    for log in system_logs:
        cw.writerow([log['time'], log['cam'], log['event']])
    output = make_response(si.getvalue())
    output.headers["Content-Disposition"] = "attachment; filename=loguri_trafic.csv"
    output.headers["Content-type"] = "text/csv"
    return output

def generate_frames(cam_id):
    while True:
        frame = latest_frames.get(cam_id)
        status = camera_data.get(cam_id, {}).get("status", "")

        if frame and status == "ONLINE":
            yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + frame + b'\r\n')
        else:
            img = np.zeros((360, 640, 3), dtype=np.uint8)
            msg = "Asteptare conexiune..."
            if status == "Se conecteaza...":
                msg = "Se preia fluxul video..."
            elif status == "EROARE CONEXIUNE":
                msg = "Eroare! Verifica IP-ul sau Portul RTSP."

            cv2.putText(img, msg, (100, 180), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2)
            _, buffer = cv2.imencode('.jpg', img)
            yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + buffer.tobytes() + b'\r\n')
        time.sleep(0.1)

@app.route('/video_feed/<cam_id>')
def video_feed(cam_id):
    return Response(generate_frames(cam_id), mimetype='multipart/x-mixed-replace; boundary=frame')

